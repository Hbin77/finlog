---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CategoryTag from '../components/CategoryTag.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: { depth: number; slug: string; text: string }[];
}

const { post, headings } = Astro.props;
const { title, description, pubDate, updatedDate, category, image, imageAlt } = post.data;

const categoryLabels: Record<string, string> = {
  saving: '저축/예금',
  investing: '투자 입문',
  tax: '세금/연말정산',
  tools: '재테크 도구',
  tips: '절약 팁',
};

const categoryUrls: Record<string, string> = {
  saving: '/category/saving/',
  investing: '/category/investing/',
  tax: '/category/tax/',
  tools: '/category/tools/',
  tips: '/category/tips/',
};

const formattedDate = pubDate.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Estimate reading time (~500 chars per minute for Korean)
const readingTime = Math.max(1, Math.ceil(post.body!.length / 500));

// Get related posts (same category, exclude current post)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.data.category === category && p.slug !== post.slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const breadcrumbItems = [
  { label: '홈', href: '/' },
  { label: categoryLabels[category], href: categoryUrls[category] },
  { label: title },
];

const postSlug = post.slug;
---

<BaseLayout
  title={`${title} | 핀로그`}
  description={description}
  image={image}
  imageAlt={imageAlt}
  type="article"
  publishedDate={pubDate}
  modifiedDate={updatedDate}
>
  <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8 py-6 md:py-10">
    <Breadcrumb items={breadcrumbItems} />

    <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">
      <!-- Main content -->
      <article>
        <!-- Article header -->
        <header class="mb-8">
          <div class="mb-3">
            <CategoryTag category={category} size="md" />
          </div>
          <h1 class="text-2xl md:text-[var(--font-size-h1)] font-bold text-[var(--color-text)] leading-tight mb-4">
            {title}
          </h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-[var(--color-neutral-500)]">
            <span style="display:inline-flex;align-items:center;gap:0.35rem;">
              <span style="width:22px;height:22px;border-radius:50%;background:var(--color-primary-100);color:var(--color-primary-600);display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;">H</span>
              <span style="font-weight:600;color:var(--color-neutral-700);">Hbin77</span>
            </span>
            <span aria-hidden="true">&middot;</span>
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            {formattedUpdatedDate && (
              <>
                <span aria-hidden="true">&middot;</span>
                <span>수정: {formattedUpdatedDate}</span>
              </>
            )}
            <span aria-hidden="true">&middot;</span>
            <span>{readingTime}분 읽기</span>
          </div>
          <div style="margin-top:0.75rem;">
            <button id="suggest-edit-btn" onclick="openSuggestionModal()" style="display:none;font-size:0.78rem;padding:0.3rem 0.75rem;border:1px solid var(--color-border);border-radius:8px;background:white;color:var(--color-neutral-600);cursor:pointer;display:inline-flex;align-items:center;gap:0.3rem;">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              수정 제안
            </button>
          </div>
        </header>

        <!-- Table of Contents (mobile: inside article) -->
        <div class="lg:hidden">
          <TableOfContents headings={headings} />
        </div>

        <!-- Article body (uses .prose styles from global.css) -->
        <div class="prose max-w-none">
          <slot />
        </div>

        <!-- Suggestion modal -->
        <div id="suggestion-modal" style="display:none;margin:2rem 0;background:#f0fdf4;border:1px solid #86efac;border-radius:14px;padding:1.5rem;">
          <h3 style="font-size:1rem;font-weight:700;color:#16a34a;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.4rem;">
            <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            수정 제안하기
          </h3>
          <p style="font-size:0.82rem;color:var(--color-neutral-500);margin-bottom:1rem;">틀린 부분이나 개선할 내용을 알려주세요. 작성자가 검토 후 반영합니다.</p>
          <div id="suggestion-msg" style="display:none;margin-bottom:0.75rem;padding:0.5rem 0.75rem;border-radius:8px;font-size:0.82rem;"></div>
          <div style="margin-bottom:0.75rem;">
            <label style="display:block;font-size:0.78rem;font-weight:600;color:#555;margin-bottom:0.25rem;">기존 내용 (수정할 부분)</label>
            <textarea id="sug-original" rows="3" placeholder="수정이 필요한 원문을 붙여넣어주세요" style="width:100%;padding:0.6rem;border:1px solid #86efac;border-radius:8px;font-size:0.88rem;box-sizing:border-box;resize:vertical;"></textarea>
          </div>
          <div style="margin-bottom:0.75rem;">
            <label style="display:block;font-size:0.78rem;font-weight:600;color:#555;margin-bottom:0.25rem;">제안 내용 (이렇게 수정)</label>
            <textarea id="sug-suggested" rows="3" placeholder="수정된 내용을 작성해주세요" style="width:100%;padding:0.6rem;border:1px solid #86efac;border-radius:8px;font-size:0.88rem;box-sizing:border-box;resize:vertical;"></textarea>
          </div>
          <div style="margin-bottom:1rem;">
            <label style="display:block;font-size:0.78rem;font-weight:600;color:#555;margin-bottom:0.25rem;">사유 (선택)</label>
            <input id="sug-reason" type="text" placeholder="예: 최신 금리 정보가 변경되었습니다" style="width:100%;padding:0.5rem 0.6rem;border:1px solid #86efac;border-radius:8px;font-size:0.88rem;box-sizing:border-box;" />
          </div>
          <div style="display:flex;justify-content:flex-end;gap:0.5rem;">
            <button onclick="closeSuggestionModal()" style="padding:0.45rem 1rem;border:1px solid var(--color-border);border-radius:8px;background:white;font-size:0.82rem;cursor:pointer;">취소</button>
            <button onclick="submitSuggestion()" id="sug-submit-btn" style="padding:0.45rem 1rem;background:#16a34a;color:white;border:none;border-radius:8px;font-size:0.82rem;font-weight:600;cursor:pointer;">제안 보내기</button>
          </div>
        </div>

        <script is:inline define:vars={{ postSlug }}>
          var _postSlug = postSlug;

          // Show suggest button only for logged in users
          fetch('/api/auth/me', { credentials: 'include' })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (data && data.user) {
                var btn = document.getElementById('suggest-edit-btn');
                if (btn) btn.style.display = 'inline-flex';
              }
            });

          function openSuggestionModal() {
            document.getElementById('suggestion-modal').style.display = 'block';
            document.getElementById('suggestion-modal').scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          function closeSuggestionModal() {
            document.getElementById('suggestion-modal').style.display = 'none';
          }
          function submitSuggestion() {
            var original = document.getElementById('sug-original').value.trim();
            var suggested = document.getElementById('sug-suggested').value.trim();
            var reason = document.getElementById('sug-reason').value.trim();
            var msgEl = document.getElementById('suggestion-msg');

            if (!original || !suggested) {
              msgEl.textContent = '기존 내용과 제안 내용을 모두 입력해주세요.';
              msgEl.style.display = 'block'; msgEl.style.background = '#fef2f2'; msgEl.style.color = '#dc2626';
              return;
            }

            var btn = document.getElementById('sug-submit-btn');
            btn.disabled = true; btn.textContent = '전송 중...';

            fetch('/api/suggestions', {
              method: 'POST', credentials: 'include',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ post_slug: _postSlug, original_text: original, suggested_text: suggested, reason: reason })
            })
            .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
            .then(function(res) {
              btn.disabled = false; btn.textContent = '제안 보내기';
              if (res.ok) {
                msgEl.textContent = '수정 제안이 전송되었습니다. 작성자가 검토 후 반영합니다.';
                msgEl.style.display = 'block'; msgEl.style.background = '#f0fdf4'; msgEl.style.color = '#16a34a';
                document.getElementById('sug-original').value = '';
                document.getElementById('sug-suggested').value = '';
                document.getElementById('sug-reason').value = '';
              } else {
                msgEl.textContent = res.data.error || '제안 전송에 실패했습니다.';
                msgEl.style.display = 'block'; msgEl.style.background = '#fef2f2'; msgEl.style.color = '#dc2626';
              }
            })
            .catch(function() {
              btn.disabled = false; btn.textContent = '제안 보내기';
              msgEl.textContent = '네트워크 오류가 발생했습니다.'; msgEl.style.display = 'block'; msgEl.style.background = '#fef2f2'; msgEl.style.color = '#dc2626';
            });
          }
        </script>

        <!-- 카카오 애드핏 광고 -->
        <div style="display:flex;justify-content:center;margin:2rem auto;">
          <ins class="kakao_ad_area" style="display:none;"
            data-ad-unit="DAN-wMmzFKVuQFxRgxPU"
            data-ad-width="320"
            data-ad-height="100"></ins>
        </div>
        <script is:inline src="//t1.daumcdn.net/kas/static/ba.min.js" async></script>

        <!-- Related posts -->
        <RelatedPosts posts={relatedPosts} />

        <!-- 쿠팡 파트너스 배너 -->
        <div style="margin:2rem auto;max-width:100%;text-align:center;">
          <script is:inline src="https://ads-partners.coupang.com/g.js"></script>
          <script is:inline>new PartnersCoupang.G({"id":971033,"template":"carousel","trackingCode":"AF1962827","width":"680","height":"140","tsource":""});</script>
          <p style="margin-top:0.5rem;font-size:0.75rem;color:#999;text-align:center;">이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.</p>
        </div>

      </article>

      <!-- Sidebar (desktop only) -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-8">
          <!-- Table of Contents -->
          <TableOfContents headings={headings} />

        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
