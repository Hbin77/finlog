---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import JsonLd from '../components/JsonLd.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  modifiedDate?: Date;
  noindex?: boolean;
}

const {
  title,
  description = '2030 직장인을 위한 실용 재테크 가이드. 저축, 투자, 세금, 절약 팁까지 알기 쉽게 정리합니다.',
  image = '/og-default.png',
  imageAlt,
  type = 'website',
  publishedDate,
  modifiedDate,
  noindex = false,
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-32.png" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="cf-site-key" content={import.meta.env.PUBLIC_CF_TURNSTILE_SITE_KEY || ''} />

    <!-- Pretendard Font -->
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />

    <!-- SEO 메타 태그 -->
    <SEOHead
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      type={type}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      noindex={noindex}
    />

    <!-- JSON-LD: 사이트 정보 -->
    <JsonLd type="WebSite" />

    <!-- Google AdSense account verification (always present) -->
    <meta name="google-adsense-account" content="ca-pub-2355375334646881" />

    <!-- GA4 + AdSense: loaded only after cookie consent -->
    <script is:inline>
      function loadTrackingScripts() {
        if (document.getElementById('ga4-script')) return;
        // GA4
        var ga = document.createElement('script');
        ga.id = 'ga4-script';
        ga.async = true;
        ga.src = 'https://www.googletagmanager.com/gtag/js?id=G-NCE5SR12EC';
        document.head.appendChild(ga);
        ga.onload = function() {
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', 'G-NCE5SR12EC');
        };
        // AdSense
        var ads = document.createElement('script');
        ads.async = true;
        ads.crossOrigin = 'anonymous';
        ads.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2355375334646881';
        document.head.appendChild(ads);
      }
      // Auto-load if consent was already given
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        loadTrackingScripts();
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-neutral-50 text-neutral-800 font-sans">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Cookie Consent Banner -->
    <div id="cookie-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9990;background:white;border-top:1px solid #e5e7eb;box-shadow:0 -4px 20px rgba(0,0,0,0.1);padding:1rem 1.5rem;animation:cookieSlideUp 0.3s ease-out;">
      <div style="max-width:960px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <p style="font-size:0.85rem;color:#555;line-height:1.5;flex:1;min-width:200px;">
          이 웹사이트는 사용자 경험 개선과 맞춤 광고 제공을 위해 쿠키를 사용합니다.
          자세한 내용은 <a href="/privacy-policy/" style="color:var(--color-primary-500);text-decoration:underline;">개인정보처리방침</a>을 참고하세요.
        </p>
        <div style="display:flex;gap:0.5rem;flex-shrink:0;">
          <button onclick="acceptCookies()" style="padding:0.5rem 1.25rem;background:var(--color-primary-500);color:white;border:none;border-radius:8px;font-size:0.82rem;font-weight:600;cursor:pointer;">동의</button>
          <button onclick="declineCookies()" style="padding:0.5rem 1rem;background:white;color:#666;border:1px solid #ddd;border-radius:8px;font-size:0.82rem;cursor:pointer;">거부</button>
        </div>
      </div>
    </div>

    <script is:inline>
      (function() {
        if (!localStorage.getItem('cookie_consent')) {
          var banner = document.getElementById('cookie-banner');
          if (banner) banner.style.display = 'block';
        }
      })();
      function acceptCookies() {
        localStorage.setItem('cookie_consent', 'accepted');
        document.getElementById('cookie-banner').style.display = 'none';
        if (typeof loadTrackingScripts === 'function') loadTrackingScripts();
      }
      function declineCookies() {
        localStorage.setItem('cookie_consent', 'declined');
        document.getElementById('cookie-banner').style.display = 'none';
      }
    </script>

    <style is:inline>
      @keyframes cookieSlideUp {
        from { opacity: 0; transform: translateY(100%); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </body>
</html>
