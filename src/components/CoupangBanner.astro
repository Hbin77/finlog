---
interface Props {
  partnerId?: string;
  subId?: string;
}

const {
  partnerId = "AF1962827",
  subId = "",
} = Astro.props;
---

<div class="coupang-banner-wrapper">
  <div id="coupang-banner"></div>
  <p class="coupang-disclosure">
    이 포스팅은 쿠팡 파트너스 활동의 일환으로, 이에 따른 일정액의 수수료를 제공받습니다.
  </p>
</div>

<script is:inline>
  (function() {
    var s = document.createElement('script');
    s.src = 'https://ads-partners.coupang.com/g.js';
    s.async = true;
    s.onload = function() {
      new PartnersCoupang.G({
        id: "AF1962827",
        template: "carousel",
        trackingCode: "AF1962827",
        subId: "",
        width: "100%",
        height: "auto",
        container: document.getElementById("coupang-banner")
      });
    };
    document.head.appendChild(s);
  })();
</script>

<style>
  .coupang-banner-wrapper {
    margin: 2rem auto;
    max-width: 100%;
  }

  #coupang-banner {
    width: 100%;
    min-height: 100px;
    overflow: hidden;
  }

  .coupang-disclosure {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: #999;
    text-align: center;
    line-height: 1.4;
  }
</style>
