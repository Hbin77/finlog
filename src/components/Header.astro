---
const navLinks = [
  { href: '/category/saving/', label: '저축/예금' },
  { href: '/category/investing/', label: '투자 입문' },
  { href: '/category/tax/', label: '세금/연말정산' },
  { href: '/category/tools/', label: '재테크 도구' },
  { href: '/category/tips/', label: '절약 팁' },
  { href: '/community/', label: '커뮤니티' },
  { href: '/about/', label: '소개' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-[var(--color-border)] shadow-[var(--shadow-sm)]">
  <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 md:h-[4.5rem] items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-[var(--color-primary-500)] text-xl font-bold tracking-tight hover:text-[var(--color-primary-600)] transition-colors duration-[var(--transition-fast)]">
        <img src="/logo.png" alt="핀로그 로고" class="w-7 h-7" />
        핀로그
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="메인 네비게이션">
        <span id="header-user-indicator" style="display:none;font-size:0.78rem;color:var(--color-neutral-500);background:var(--color-primary-50);padding:0.25rem 0.6rem;border-radius:999px;font-weight:500;"></span>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors duration-[var(--transition-fast)]',
              currentPath.startsWith(link.href)
                ? 'text-[var(--color-secondary-500)] border-b-2 border-[var(--color-secondary-500)] pb-1'
                : 'text-[var(--color-neutral-600)] hover:text-[var(--color-secondary-500)]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Toggle -->
      <label for="mobile-menu-toggle" class="md:hidden cursor-pointer p-2 -mr-2 text-[var(--color-neutral-600)] hover:text-[var(--color-primary-500)]" aria-label="메뉴 열기">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>

  <!-- Mobile Menu (CSS-only) -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
  <div class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-96 transition-all duration-300 ease-in-out border-t border-[var(--color-border)] peer-checked:border-t">
    <nav class="mx-auto max-w-[var(--container-max-width)] px-4 py-3 flex flex-col gap-1" aria-label="모바일 네비게이션">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-3 py-2.5 rounded-[var(--radius-md)] text-sm font-medium transition-colors duration-[var(--transition-fast)]',
            currentPath.startsWith(link.href)
              ? 'bg-[var(--color-secondary-50)] text-[var(--color-secondary-600)]'
              : 'text-[var(--color-neutral-600)] hover:bg-[var(--color-neutral-50)] hover:text-[var(--color-secondary-500)]',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
<script is:inline>
  (function() {
    fetch('/api/auth/me', { credentials: 'include' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (data && data.user) {
          var el = document.getElementById('header-user-indicator');
          if (el) {
            el.textContent = (data.user.nickname || data.user.name || '사용자') + '님';
            el.style.display = 'inline-block';
          }
        }
      })
      .catch(function() {});
  })();
</script>
</header>
