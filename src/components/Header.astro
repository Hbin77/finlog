---
const navLinks = [
  { href: '/category/saving/', label: '저축/예금' },
  { href: '/category/investing/', label: '투자 입문' },
  { href: '/category/tax/', label: '세금/연말정산' },
  { href: '/category/tools/', label: '재테크 도구' },
  { href: '/category/tips/', label: '절약 팁' },
  { href: '/community/', label: '커뮤니티' },
  { href: '/about/', label: '소개' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-[var(--color-border)] shadow-[var(--shadow-sm)]">
  <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 md:h-[4.5rem] items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-[var(--color-primary-500)] text-xl font-bold tracking-tight hover:text-[var(--color-primary-600)] transition-colors duration-[var(--transition-fast)]">
        <img src="/logo.png" alt="핀로그 로고" class="w-7 h-7" />
        핀로그
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-6 lg:gap-8" aria-label="메인 네비게이션">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors duration-[var(--transition-fast)]',
              currentPath.startsWith(link.href)
                ? 'text-[var(--color-secondary-500)] border-b-2 border-[var(--color-secondary-500)] pb-1'
                : 'text-[var(--color-neutral-600)] hover:text-[var(--color-secondary-500)]',
            ]}
          >
            {link.label}
          </a>
        ))}
        <div id="header-auth" style="display:flex;align-items:center;gap:0.5rem;margin-left:0.5rem;"></div>
      </nav>

      <!-- Mobile: auth + hamburger -->
      <div class="flex md:hidden items-center gap-2">
        <div id="header-auth-mobile" style="display:flex;align-items:center;gap:0.4rem;"></div>
        <label for="mobile-menu-toggle" class="cursor-pointer p-2 -mr-2 text-[var(--color-neutral-600)] hover:text-[var(--color-primary-500)]" aria-label="메뉴 열기">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <input type="checkbox" id="mobile-menu-toggle" class="peer hidden" aria-hidden="true" />
  <div class="md:hidden max-h-0 overflow-hidden peer-checked:max-h-96 transition-all duration-300 ease-in-out border-t border-[var(--color-border)] peer-checked:border-t">
    <nav class="mx-auto max-w-[var(--container-max-width)] px-4 py-3 flex flex-col gap-1" aria-label="모바일 네비게이션">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-3 py-2.5 rounded-[var(--radius-md)] text-sm font-medium transition-colors duration-[var(--transition-fast)]',
            currentPath.startsWith(link.href)
              ? 'bg-[var(--color-secondary-50)] text-[var(--color-secondary-600)]'
              : 'text-[var(--color-neutral-600)] hover:bg-[var(--color-neutral-50)] hover:text-[var(--color-secondary-500)]',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Auth Modal -->
  <div id="auth-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);">
    <div id="auth-modal-inner" style="max-width:420px;margin:8vh auto;background:white;border-radius:16px;padding:0;position:relative;animation:authSlideUp 0.25s ease-out;max-height:85vh;overflow-y:auto;">
      <button onclick="closeAuthModal()" style="position:absolute;top:0.75rem;right:1rem;background:none;border:none;font-size:1.4rem;cursor:pointer;color:#999;line-height:1;z-index:1;">&times;</button>

      <!-- Tabs -->
      <div style="display:flex;border-bottom:2px solid #f0f0f0;position:sticky;top:0;background:white;border-radius:16px 16px 0 0;">
        <button id="tab-login" onclick="switchAuthTab('login')" style="flex:1;padding:1rem 0;font-size:0.95rem;font-weight:700;border:none;background:none;cursor:pointer;color:var(--color-primary-500);border-bottom:2px solid var(--color-primary-500);margin-bottom:-2px;">로그인</button>
        <button id="tab-signup" onclick="switchAuthTab('signup')" style="flex:1;padding:1rem 0;font-size:0.95rem;font-weight:700;border:none;background:none;cursor:pointer;color:#aaa;border-bottom:2px solid transparent;margin-bottom:-2px;">회원가입</button>
      </div>

      <!-- Login Panel -->
      <div id="panel-login" style="padding:1.5rem 2rem 2rem;">
        <div id="login-msg" style="display:none;margin-bottom:1rem;padding:0.6rem 0.8rem;border-radius:8px;font-size:0.82rem;"></div>

        <!-- Email login form -->
        <div style="margin-bottom:1.25rem;">
          <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">이메일</label>
          <input id="login-email" type="email" placeholder="example@email.com" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>
        <div style="margin-bottom:0.5rem;">
          <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">비밀번호</label>
          <input id="login-password" type="password" placeholder="8자 이상" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>
        <div style="text-align:right;margin-bottom:1rem;">
          <button onclick="showForgotPassword()" style="background:none;border:none;font-size:0.78rem;color:var(--color-primary-500);cursor:pointer;text-decoration:underline;">비밀번호를 잊으셨나요?</button>
        </div>

        <!-- Turnstile widget -->
        <div id="turnstile-login" style="display:flex;justify-content:center;margin-bottom:1rem;"></div>

        <button onclick="doLogin()" id="login-submit-btn" style="width:100%;padding:0.7rem;background:var(--color-primary-500);color:white;border:none;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;margin-bottom:1.25rem;">로그인</button>

        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
          <div style="flex:1;height:1px;background:#e5e7eb;"></div>
          <span style="font-size:0.75rem;color:#aaa;">또는</span>
          <div style="flex:1;height:1px;background:#e5e7eb;"></div>
        </div>

        <a href="/api/auth/google" style="display:flex;align-items:center;justify-content:center;gap:0.6rem;padding:0.65rem;border:1px solid #ddd;border-radius:10px;background:white;font-size:0.85rem;color:#333;text-decoration:none;font-weight:500;margin-bottom:0.6rem;">
          <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Google로 로그인
        </a>
        <a href="/api/auth/kakao" style="display:flex;align-items:center;justify-content:center;gap:0.6rem;padding:0.65rem;border-radius:10px;background:#FEE500;font-size:0.85rem;color:#3C1E1E;text-decoration:none;font-weight:600;">
          <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#3C1E1E" d="M12 3C6.48 3 2 6.36 2 10.44c0 2.62 1.75 4.93 4.38 6.24l-1.12 4.16c-.08.3.26.54.52.37l4.97-3.28c.41.04.82.07 1.25.07 5.52 0 10-3.36 10-7.56S17.52 3 12 3z"/></svg>
          카카오로 로그인
        </a>
      </div>

      <!-- Signup Panel -->
      <div id="panel-signup" style="display:none;padding:1.5rem 2rem 2rem;">
        <div id="signup-msg" style="display:none;margin-bottom:1rem;padding:0.6rem 0.8rem;border-radius:8px;font-size:0.82rem;"></div>

        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">닉네임</label>
          <input id="signup-nickname" type="text" placeholder="2~20자" maxlength="20" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>
        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">이메일</label>
          <input id="signup-email" type="email" placeholder="example@email.com" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>
        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">비밀번호</label>
          <input id="signup-password" type="password" placeholder="8자 이상" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>
        <div style="margin-bottom:1rem;">
          <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">비밀번호 확인</label>
          <input id="signup-password2" type="password" placeholder="비밀번호 재입력" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>

        <!-- Turnstile widget -->
        <div id="turnstile-signup" style="display:flex;justify-content:center;margin-bottom:1rem;"></div>

        <button onclick="doSignup()" id="signup-submit-btn" style="width:100%;padding:0.7rem;background:var(--color-primary-500);color:white;border:none;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;margin-bottom:1.25rem;">회원가입</button>

        <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;">
          <div style="flex:1;height:1px;background:#e5e7eb;"></div>
          <span style="font-size:0.75rem;color:#aaa;">또는 소셜 가입</span>
          <div style="flex:1;height:1px;background:#e5e7eb;"></div>
        </div>

        <a href="/api/auth/google" style="display:flex;align-items:center;justify-content:center;gap:0.6rem;padding:0.65rem;border:1px solid #ddd;border-radius:10px;background:white;font-size:0.85rem;color:#333;text-decoration:none;font-weight:500;margin-bottom:0.6rem;">
          <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          Google로 가입
        </a>
        <a href="/api/auth/kakao" style="display:flex;align-items:center;justify-content:center;gap:0.6rem;padding:0.65rem;border-radius:10px;background:#FEE500;font-size:0.85rem;color:#3C1E1E;text-decoration:none;font-weight:600;">
          <svg width="16" height="16" viewBox="0 0 24 24"><path fill="#3C1E1E" d="M12 3C6.48 3 2 6.36 2 10.44c0 2.62 1.75 4.93 4.38 6.24l-1.12 4.16c-.08.3.26.54.52.37l4.97-3.28c.41.04.82.07 1.25.07 5.52 0 10-3.36 10-7.56S17.52 3 12 3z"/></svg>
          카카오로 가입
        </a>
        <p style="text-align:center;font-size:0.72rem;color:#aaa;margin-top:1rem;">가입 시 <a href="/privacy/" style="color:var(--color-primary-500);">개인정보처리방침</a>에 동의합니다.</p>
      </div>

      <!-- Forgot Password Panel -->
      <div id="panel-forgot" style="display:none;padding:1.5rem 2rem 2rem;">
        <div id="forgot-msg" style="display:none;margin-bottom:1rem;padding:0.6rem 0.8rem;border-radius:8px;font-size:0.82rem;"></div>
        <p style="font-size:0.88rem;color:#666;margin-bottom:1.25rem;line-height:1.5;">가입한 이메일을 입력하시면 비밀번호 재설정 링크를 보내드립니다.</p>
        <div style="margin-bottom:1rem;">
          <input id="forgot-email" type="email" placeholder="이메일 주소" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
        </div>
        <button onclick="doForgotPassword()" style="width:100%;padding:0.7rem;background:var(--color-primary-500);color:white;border:none;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;margin-bottom:1rem;">재설정 이메일 보내기</button>
        <button onclick="switchAuthTab('login')" style="width:100%;padding:0.5rem;background:none;border:none;font-size:0.82rem;color:var(--color-primary-500);cursor:pointer;">로그인으로 돌아가기</button>
      </div>
    </div>
  </div>
</header>

<!-- Cloudflare Turnstile -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>

<script is:inline>
  var _cfSiteKey = document.querySelector('meta[name="cf-site-key"]')?.content || '';
  var _turnstileLoginId = null;
  var _turnstileSignupId = null;
  var _turnstileLoginToken = '';
  var _turnstileSignupToken = '';

  function renderTurnstile() {
    if (typeof turnstile === 'undefined') { setTimeout(renderTurnstile, 300); return; }
    if (!_cfSiteKey) return;

    var loginEl = document.getElementById('turnstile-login');
    var signupEl = document.getElementById('turnstile-signup');

    if (loginEl && _turnstileLoginId === null) {
      _turnstileLoginId = turnstile.render('#turnstile-login', {
        sitekey: _cfSiteKey, size: 'normal',
        callback: function(t) { _turnstileLoginToken = t; },
      });
    }
    if (signupEl && _turnstileSignupId === null) {
      _turnstileSignupId = turnstile.render('#turnstile-signup', {
        sitekey: _cfSiteKey, size: 'normal',
        callback: function(t) { _turnstileSignupToken = t; },
      });
    }
  }

  function openAuthModal(tab) {
    document.getElementById('auth-modal').style.display = 'block';
    document.body.style.overflow = 'hidden';
    switchAuthTab(tab || 'login');
    setTimeout(renderTurnstile, 200);
  }

  function closeAuthModal() {
    document.getElementById('auth-modal').style.display = 'none';
    document.body.style.overflow = '';
  }

  function switchAuthTab(tab) {
    var tl = document.getElementById('tab-login');
    var ts = document.getElementById('tab-signup');
    var pl = document.getElementById('panel-login');
    var ps = document.getElementById('panel-signup');
    var pf = document.getElementById('panel-forgot');

    tl.style.color = '#aaa'; tl.style.borderBottomColor = 'transparent';
    ts.style.color = '#aaa'; ts.style.borderBottomColor = 'transparent';
    pl.style.display = 'none'; ps.style.display = 'none'; pf.style.display = 'none';

    if (tab === 'login') {
      tl.style.color = 'var(--color-primary-500)'; tl.style.borderBottomColor = 'var(--color-primary-500)';
      pl.style.display = 'block';
    } else if (tab === 'signup') {
      ts.style.color = 'var(--color-primary-500)'; ts.style.borderBottomColor = 'var(--color-primary-500)';
      ps.style.display = 'block';
    } else if (tab === 'forgot') {
      pf.style.display = 'block';
    }
  }

  function showMsg(id, msg, isError) {
    var el = document.getElementById(id);
    el.textContent = msg;
    el.style.display = 'block';
    el.style.background = isError ? '#fef2f2' : '#f0fdf4';
    el.style.color = isError ? '#dc2626' : '#16a34a';
  }

  function showForgotPassword() { switchAuthTab('forgot'); }

  function doLogin() {
    var email = document.getElementById('login-email').value.trim();
    var password = document.getElementById('login-password').value;
    if (!email || !password) { showMsg('login-msg', '이메일과 비밀번호를 입력해주세요.', true); return; }

    var btn = document.getElementById('login-submit-btn');
    btn.disabled = true; btn.textContent = '로그인 중...';

    fetch('/api/auth/login', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, password: password, turnstileToken: _turnstileLoginToken })
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      btn.disabled = false; btn.textContent = '로그인';
      if (res.ok && res.data.success) {
        closeAuthModal();
        location.reload();
      } else {
        showMsg('login-msg', res.data.error || '로그인에 실패했습니다.', true);
        if (res.data.needVerify) {
          document.getElementById('login-msg').innerHTML += '<br/><button onclick="resendVerify(\'' + email + '\')" style="margin-top:0.5rem;font-size:0.78rem;color:var(--color-primary-500);background:none;border:none;cursor:pointer;text-decoration:underline;">인증 이메일 다시 보내기</button>';
        }
        if (typeof turnstile !== 'undefined' && _turnstileLoginId !== null) turnstile.reset(_turnstileLoginId);
      }
    })
    .catch(function() { btn.disabled = false; btn.textContent = '로그인'; showMsg('login-msg', '네트워크 오류가 발생했습니다.', true); });
  }

  function doSignup() {
    var nickname = document.getElementById('signup-nickname').value.trim();
    var email = document.getElementById('signup-email').value.trim();
    var pw = document.getElementById('signup-password').value;
    var pw2 = document.getElementById('signup-password2').value;

    if (!nickname || !email || !pw) { showMsg('signup-msg', '모든 항목을 입력해주세요.', true); return; }
    if (pw !== pw2) { showMsg('signup-msg', '비밀번호가 일치하지 않습니다.', true); return; }
    if (pw.length < 8) { showMsg('signup-msg', '비밀번호는 8자 이상이어야 합니다.', true); return; }

    var btn = document.getElementById('signup-submit-btn');
    btn.disabled = true; btn.textContent = '가입 처리중...';

    fetch('/api/auth/signup', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email, password: pw, nickname: nickname, turnstileToken: _turnstileSignupToken })
    })
    .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
    .then(function(res) {
      btn.disabled = false; btn.textContent = '회원가입';
      if (res.ok && res.data.success) {
        if (res.data.autoLogin) {
          closeAuthModal();
          location.reload();
          return;
        }
        showMsg('signup-msg', res.data.message, false);
      } else {
        showMsg('signup-msg', res.data.error || '회원가입에 실패했습니다.', true);
        if (typeof turnstile !== 'undefined' && _turnstileSignupId !== null) turnstile.reset(_turnstileSignupId);
      }
    })
    .catch(function() { btn.disabled = false; btn.textContent = '회원가입'; showMsg('signup-msg', '네트워크 오류가 발생했습니다.', true); });
  }

  function resendVerify(email) {
    fetch('/api/auth/resend-verification', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) { showMsg('login-msg', d.message || '인증 이메일을 보냈습니다.', false); });
  }

  function doForgotPassword() {
    var email = document.getElementById('forgot-email').value.trim();
    if (!email) { showMsg('forgot-msg', '이메일을 입력해주세요.', true); return; }
    fetch('/api/auth/forgot-password', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) { showMsg('forgot-msg', d.message || '이메일을 전송했습니다.', false); });
  }

  // Close modal on background click
  document.getElementById('auth-modal').addEventListener('click', function(e) {
    if (e.target === this) closeAuthModal();
  });

  // Enter key support
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
      if (document.getElementById('panel-login').style.display !== 'none' && document.activeElement.id && document.activeElement.id.startsWith('login-')) doLogin();
      if (document.getElementById('panel-signup').style.display !== 'none' && document.activeElement.id && document.activeElement.id.startsWith('signup-')) doSignup();
    }
    if (e.key === 'Escape') closeAuthModal();
  });

  // Auth state
  (function() {
    fetch('/api/auth/me', { credentials: 'include' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        var desktop = document.getElementById('header-auth');
        var mobile = document.getElementById('header-auth-mobile');
        if (data && data.user) {
          var name = data.user.nickname || '사용자';
          var loggedIn = '<a href="/mypage/" style="font-size:0.8rem;color:var(--color-neutral-600);background:var(--color-primary-50);padding:0.3rem 0.7rem;border-radius:999px;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;gap:0.3rem;">' +
            '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>' +
            name + '</a>' +
            '<button onclick="fetch(\'/api/auth/logout\',{method:\'POST\',credentials:\'include\'}).then(function(){location.reload()})" style="font-size:0.75rem;padding:0.25rem 0.6rem;border:1px solid var(--color-border);border-radius:8px;background:white;cursor:pointer;color:var(--color-neutral-500);">로그아웃</button>';
          if (desktop) desktop.innerHTML = loggedIn;
          if (mobile) mobile.innerHTML = '<a href="/mypage/" style="font-size:0.72rem;color:var(--color-neutral-500);background:var(--color-primary-50);padding:0.2rem 0.5rem;border-radius:999px;text-decoration:none;">' + name + '</a>';
        } else {
          var buttons = '<button onclick="openAuthModal(\'login\')" style="font-size:0.8rem;padding:0.3rem 0.85rem;border:1px solid var(--color-primary-500);border-radius:8px;background:white;color:var(--color-primary-500);cursor:pointer;font-weight:600;">로그인</button>' +
            '<button onclick="openAuthModal(\'signup\')" style="font-size:0.8rem;padding:0.3rem 0.85rem;border:none;border-radius:8px;background:var(--color-primary-500);color:white;cursor:pointer;font-weight:600;">회원가입</button>';
          if (desktop) desktop.innerHTML = buttons;
          if (mobile) mobile.innerHTML = '<button onclick="openAuthModal(\'login\')" style="font-size:0.72rem;padding:0.25rem 0.6rem;border:none;border-radius:6px;background:var(--color-primary-500);color:white;cursor:pointer;font-weight:600;">로그인</button>';
        }
      })
      .catch(function() {
        var desktop = document.getElementById('header-auth');
        var mobile = document.getElementById('header-auth-mobile');
        var buttons = '<button onclick="openAuthModal(\'login\')" style="font-size:0.8rem;padding:0.3rem 0.85rem;border:1px solid var(--color-primary-500);border-radius:8px;background:white;color:var(--color-primary-500);cursor:pointer;font-weight:600;">로그인</button>' +
          '<button onclick="openAuthModal(\'signup\')" style="font-size:0.8rem;padding:0.3rem 0.85rem;border:none;border-radius:8px;background:var(--color-primary-500);color:white;cursor:pointer;font-weight:600;">회원가입</button>';
        if (desktop) desktop.innerHTML = buttons;
        if (mobile) mobile.innerHTML = '<button onclick="openAuthModal(\'login\')" style="font-size:0.72rem;padding:0.25rem 0.6rem;border:none;border-radius:6px;background:var(--color-primary-500);color:white;cursor:pointer;font-weight:600;">로그인</button>';
      });

    // Check URL params for auth messages
    var params = new URLSearchParams(window.location.search);
    if (params.get('auth_success') === 'verified') {
      alert('이메일 인증이 완료되었습니다! 환영합니다.');
      history.replaceState(null, '', window.location.pathname);
    }
    if (params.get('auth_error')) {
      var errors = { invalid_token: '유효하지 않은 인증 링크입니다.', expired_token: '만료된 인증 링크입니다.', verify_failed: '인증에 실패했습니다.' };
      alert(errors[params.get('auth_error')] || '인증 오류가 발생했습니다.');
      history.replaceState(null, '', window.location.pathname);
    }
  })();
</script>

<style is:inline>
  @keyframes authSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
