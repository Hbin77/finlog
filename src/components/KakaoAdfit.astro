---
interface Props {
  adUnitId?: string;
  width?: number;
  height?: number;
}

const {
  adUnitId = "DAN-wMmzFKVuQFxRgxPU",
  width = 320,
  height = 100,
} = Astro.props;
---

<div class="kakao-adfit-wrapper">
  <ins
    class="kakao_ad_area"
    style="display:none;"
    data-ad-unit={adUnitId}
    data-ad-width={String(width)}
    data-ad-height={String(height)}
  ></ins>
</div>

<script is:inline src="https://t1.daumcdn.net/kas/static/ba.min.js" async></script>

<style>
  .kakao-adfit-wrapper {
    display: flex;
    justify-content: center;
    margin: 2rem auto;
    max-width: 100%;
    overflow: hidden;
  }
</style>
