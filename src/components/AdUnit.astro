---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['ad-unit', className]}>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-2355375334646881"
    data-ad-slot="auto"
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>

<style>
  .ad-unit {
    width: 100%;
    overflow: hidden;
    text-align: center;
  }
</style>
