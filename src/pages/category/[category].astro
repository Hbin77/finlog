---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CategoryTag from '../../components/CategoryTag.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const categories = ['saving', 'investing', 'tax', 'tools', 'tips'];
  return categories.map((category) => ({
    params: { category },
  }));
};

const categoryMeta: Record<string, { label: string; description: string }> = {
  saving: {
    label: '저축/예금 전략',
    description: '월급 관리법, 적금 비교, 비상금 마련 등 안정적인 자산 형성을 위한 저축 전략을 소개합니다.',
  },
  investing: {
    label: '투자 입문',
    description: 'ETF, 주식, 펀드, ISA 등 초보 투자자를 위한 기초부터 실전까지 안내합니다.',
  },
  tax: {
    label: '세금/연말정산',
    description: '연말정산 절세 전략, 소득공제, 세액공제, 종합소득세 신고 등 세금 관련 정보를 정리합니다.',
  },
  tools: {
    label: '재테크 도구 리뷰',
    description: '가계부 앱, 인터넷은행, 자산관리 앱 등 재테크에 유용한 도구와 서비스를 비교 리뷰합니다.',
  },
  tips: {
    label: '생활비 절약 팁',
    description: '식비, 통신비, 보험료, 구독 서비스 정리 등 일상에서 실천할 수 있는 절약 방법을 공유합니다.',
  },
};

const { category } = Astro.params;
const meta = categoryMeta[category!];

const posts = await getCollection('blog', ({ data }) => !data.draft && data.category === category);
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const breadcrumbItems = [
  { label: '홈', href: '/' },
  { label: '블로그', href: '/blog/' },
  { label: meta.label },
];
---

<BaseLayout title={`${meta.label} | 핀로그`} description={meta.description}>
  <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Category header -->
    <div class="mb-8">
      <div class="mb-3">
        <CategoryTag category={category as any} size="md" />
      </div>
      <h1 class="text-2xl md:text-[var(--font-size-h1)] font-bold text-[var(--color-text)] mb-2">
        {meta.label}
      </h1>
      <p class="text-[var(--color-text-sub)]">{meta.description}</p>
    </div>

    <!-- Posts grid -->
    {sortedPosts.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-[var(--color-neutral-500)]">이 카테고리에 아직 작성된 글이 없습니다.</p>
      </div>
    )}
  </div>
</BaseLayout>
