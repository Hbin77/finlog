---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="글쓰기 | 핀로그" description="블로그 글을 작성하세요." noindex={true}>
  <div class="mx-auto max-w-[1200px] px-4 sm:px-6 lg:px-8 py-6 md:py-10">

    <!-- Not logged in -->
    <div id="not-logged-in" style="display:none;text-align:center;padding:4rem 1rem;">
      <svg width="48" height="48" fill="none" stroke="#ccc" viewBox="0 0 24 24" style="margin:0 auto 1rem;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      <p style="font-size:1.1rem;color:var(--color-neutral-500);margin-bottom:1.5rem;">로그인 후 글을 작성할 수 있습니다.</p>
      <button id="login-btn" style="padding:0.6rem 1.5rem;background:var(--color-primary-500);color:white;border:none;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;">로그인</button>
    </div>

    <!-- Editor section -->
    <div id="editor-section" style="display:none;">
      <!-- Header -->
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;">
        <h1 style="font-size:1.5rem;font-weight:800;color:var(--color-neutral-900);">새 글 작성</h1>
        <div style="display:flex;gap:0.5rem;">
          <a href="javascript:history.back()" style="padding:0.5rem 1rem;border:1px solid var(--color-border);border-radius:8px;background:white;font-size:0.85rem;cursor:pointer;color:var(--color-neutral-600);text-decoration:none;">취소</a>
          <button id="publish-btn" style="padding:0.5rem 1.25rem;background:var(--color-primary-500);color:white;border:none;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;">발행하기</button>
        </div>
      </div>

      <!-- Title -->
      <input id="post-title" type="text" placeholder="제목을 입력하세요" maxlength="200" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--color-border);border-radius:10px;font-size:1.25rem;font-weight:700;margin-bottom:1rem;box-sizing:border-box;color:var(--color-neutral-900);" />

      <!-- Category + meta row -->
      <div style="display:flex;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap;">
        <select id="post-category" style="padding:0.5rem 0.75rem;border:1px solid var(--color-border);border-radius:8px;font-size:0.88rem;color:var(--color-neutral-700);background:white;">
          <option value="saving">저축/예금</option>
          <option value="investing">투자 입문</option>
          <option value="tax">세금/연말정산</option>
          <option value="tools">재테크 도구</option>
          <option value="tips">절약 팁</option>
          <option value="general">자유</option>
        </select>
        <input id="post-image" type="text" placeholder="커버 이미지 URL (선택)" style="flex:1;min-width:200px;padding:0.5rem 0.75rem;border:1px solid var(--color-border);border-radius:8px;font-size:0.88rem;box-sizing:border-box;" />
      </div>

      <!-- Toolbar -->
      <div id="toolbar" style="display:flex;flex-wrap:wrap;gap:0.25rem;padding:0.5rem 0.75rem;background:#f8fafc;border:1px solid var(--color-border);border-bottom:none;border-radius:10px 10px 0 0;">
        <button class="tb" data-action="h2" title="제목 (H2)">H2</button>
        <button class="tb" data-action="h3" title="소제목 (H3)">H3</button>
        <span style="width:1px;background:#ddd;margin:0 0.25rem;"></span>
        <button class="tb" data-action="bold" title="굵게"><b>B</b></button>
        <button class="tb" data-action="italic" title="기울임"><i>I</i></button>
        <button class="tb" data-action="strikethrough" title="취소선"><s>S</s></button>
        <span style="width:1px;background:#ddd;margin:0 0.25rem;"></span>
        <button class="tb" data-action="ul" title="목록">• 목록</button>
        <button class="tb" data-action="ol" title="번호 목록">1. 목록</button>
        <button class="tb" data-action="blockquote" title="인용구">" 인용</button>
        <span style="width:1px;background:#ddd;margin:0 0.25rem;"></span>
        <button class="tb" data-action="link" title="링크"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg> 링크</button>
        <button class="tb" data-action="image" title="이미지"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg> 이미지</button>
        <button class="tb" data-action="table" title="표"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18M10 3v18M14 3v18M3 6a3 3 0 013-3h12a3 3 0 013 3v12a3 3 0 01-3 3H6a3 3 0 01-3-3V6z"/></svg> 표</button>
        <span style="width:1px;background:#ddd;margin:0 0.25rem;"></span>
        <button class="tb" data-action="code" title="인라인 코드">`코드`</button>
        <button class="tb" data-action="codeblock" title="코드 블록">```블록```</button>
        <button class="tb" data-action="hr" title="구분선">── 구분선</button>
      </div>

      <!-- Hidden file input for image upload -->
      <input type="file" id="image-upload" accept="image/*" style="display:none;" />
      <div id="upload-progress" style="display:none;margin-bottom:0.5rem;padding:0.5rem 0.75rem;background:var(--color-primary-50);border-radius:8px;font-size:0.82rem;color:var(--color-primary-600);">업로드 중...</div>

      <!-- Editor + Preview -->
      <div style="display:flex;gap:0;border:1px solid var(--color-border);border-radius:0 0 10px 10px;min-height:500px;overflow:hidden;" id="editor-container">
        <!-- Editor -->
        <div style="flex:1;display:flex;flex-direction:column;border-right:1px solid var(--color-border);">
          <div style="padding:0.4rem 0.75rem;background:#f8fafc;font-size:0.72rem;font-weight:600;color:var(--color-neutral-400);border-bottom:1px solid var(--color-border);">마크다운</div>
          <textarea id="post-body" placeholder="마크다운으로 글을 작성하세요...

## 소제목을 입력하세요

본문 내용을 작성합니다. **굵게** 또는 *기울임*으로 강조할 수 있습니다.

- 목록 항목 1
- 목록 항목 2

> 인용구를 넣을 수 있습니다.

| 항목 | 내용 |
|------|------|
| A | 설명 |
| B | 설명 |" style="flex:1;padding:1rem;border:none;font-size:0.92rem;resize:none;outline:none;font-family:'Pretendard Variable',sans-serif;line-height:1.8;box-sizing:border-box;width:100%;"></textarea>
        </div>
        <!-- Preview -->
        <div style="flex:1;display:flex;flex-direction:column;">
          <div style="padding:0.4rem 0.75rem;background:#f8fafc;font-size:0.72rem;font-weight:600;color:var(--color-neutral-400);border-bottom:1px solid var(--color-border);">미리보기</div>
          <div id="preview" class="prose max-w-none" style="flex:1;padding:1rem;overflow-y:auto;">
            <p style="color:var(--color-neutral-400);">미리보기가 여기에 표시됩니다...</p>
          </div>
        </div>
      </div>

      <!-- Status message -->
      <div id="status-msg" style="display:none;margin-top:1rem;padding:0.6rem 1rem;border-radius:8px;font-size:0.85rem;"></div>

      <!-- Tips -->
      <div style="margin-top:1.5rem;background:white;border:1px solid var(--color-border);border-radius:12px;overflow:hidden;">
        <div style="padding:0.6rem 1rem;background:var(--color-primary-50);border-bottom:1px solid var(--color-border);display:flex;align-items:center;gap:0.4rem;">
          <svg width="14" height="14" fill="none" stroke="var(--color-primary-500)" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span style="font-size:0.8rem;font-weight:600;color:var(--color-primary-600);">마크다운 문법 가이드</span>
        </div>
        <div style="padding:0.75rem 1rem;display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:0.4rem 1.5rem;font-size:0.78rem;color:var(--color-neutral-500);">
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">## 텍스트</code> 제목</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">**텍스트**</code> 굵게</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">*텍스트*</code> 기울임</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">- 항목</code> 목록</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">[텍스트](URL)</code> 링크</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">![설명](URL)</code> 이미지</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">> 텍스트</code> 인용구</div>
          <div><code style="background:var(--color-primary-50);color:var(--color-primary-600);padding:0.1rem 0.35rem;border-radius:4px;font-size:0.72rem;">| A | B |</code> 표</div>
        </div>
      </div>
    </div>
  </div>

  <!-- marked.js + DOMPurify from CDN -->
  <script src="https://cdn.jsdelivr.net/npm/marked@15.0.7/marked.min.js" is:inline></script>
  <script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.4/dist/purify.min.js" is:inline></script>

  <script is:inline>
    // Auth check
    fetch('/api/auth/me', { credentials: 'include' })
      .then(function(r) { return r.ok ? r.json() : null; })
      .then(function(data) {
        if (data && data.user) {
          document.getElementById('editor-section').style.display = 'block';
        } else {
          document.getElementById('not-logged-in').style.display = 'block';
        }
      })
      .catch(function() {
        document.getElementById('not-logged-in').style.display = 'block';
      });

    // Pre-select category from URL param
    var params = new URLSearchParams(window.location.search);
    var preCategory = params.get('category');
    if (preCategory) {
      var sel = document.getElementById('post-category');
      if (sel) sel.value = preCategory;
    }

    // Login button
    document.getElementById('login-btn').addEventListener('click', function() {
      if (typeof openAuthModal === 'function') openAuthModal('login');
    });

    // Toolbar actions
    var textarea = document.getElementById('post-body');

    // Toggle wrap: if selection already has before/after, remove them; otherwise add them
    function toggleWrap(before, after, placeholder) {
      var start = textarea.selectionStart;
      var end = textarea.selectionEnd;
      var val = textarea.value;
      var selected = val.substring(start, end);

      // Check if already wrapped
      var bLen = before.length;
      var aLen = (after || '').length;
      if (start >= bLen && val.substring(start - bLen, start) === before &&
          val.substring(end, end + aLen) === (after || '')) {
        // Remove wrapping
        textarea.value = val.substring(0, start - bLen) + selected + val.substring(end + aLen);
        textarea.selectionStart = start - bLen;
        textarea.selectionEnd = end - bLen;
      } else {
        // Add wrapping
        var text = selected || placeholder || '';
        textarea.setRangeText(before + text + (after || ''), start, end, 'end');
        if (!selected && placeholder) {
          textarea.selectionStart = start + bLen;
          textarea.selectionEnd = start + bLen + text.length;
        }
      }
      textarea.focus();
      updatePreview();
    }

    // Toggle line prefix: if line starts with prefix, remove it; otherwise add it
    function toggleLine(prefix) {
      var start = textarea.selectionStart;
      var val = textarea.value;
      var lineStart = val.lastIndexOf('\n', start - 1) + 1;
      var lineEnd = val.indexOf('\n', start);
      if (lineEnd === -1) lineEnd = val.length;
      var line = val.substring(lineStart, lineEnd);

      if (line.startsWith(prefix)) {
        // Remove prefix
        textarea.value = val.substring(0, lineStart) + line.substring(prefix.length) + val.substring(lineEnd);
        textarea.selectionStart = textarea.selectionEnd = Math.max(lineStart, start - prefix.length);
      } else {
        // Add prefix
        textarea.value = val.substring(0, lineStart) + prefix + line + val.substring(lineEnd);
        textarea.selectionStart = textarea.selectionEnd = start + prefix.length;
      }
      textarea.focus();
      updatePreview();
    }

    function insertText(text) {
      var start = textarea.selectionStart;
      textarea.setRangeText(text, start, textarea.selectionEnd, 'end');
      textarea.focus();
      updatePreview();
    }

    var ACTIONS = {
      h2: function() { toggleLine('## '); },
      h3: function() { toggleLine('### '); },
      bold: function() { toggleWrap('**', '**', '굵은 텍스트'); },
      italic: function() { toggleWrap('*', '*', '기울임 텍스트'); },
      strikethrough: function() { toggleWrap('~~', '~~', '취소선 텍스트'); },
      ul: function() { toggleLine('- '); },
      ol: function() { toggleLine('1. '); },
      blockquote: function() { toggleLine('> '); },
      link: function() {
        var url = prompt('링크 URL을 입력하세요:', 'https://');
        if (url) toggleWrap('[', '](' + url + ')', '링크 텍스트');
      },
      image: function() { document.getElementById('image-upload').click(); },
      table: function() {
        insertText('\n| 항목 | 내용 | 비고 |\n|------|------|------|\n| A | 설명 | - |\n| B | 설명 | - |\n');
      },
      code: function() { toggleWrap('`', '`', '코드'); },
      codeblock: function() { toggleWrap('\n```\n', '\n```\n', '코드 블록'); },
      hr: function() { insertText('\n---\n'); }
    };

    document.getElementById('toolbar').addEventListener('click', function(e) {
      var btn = e.target.closest('.tb');
      if (!btn) return;
      var action = btn.getAttribute('data-action');
      if (ACTIONS[action]) ACTIONS[action]();
    });

    // Image file upload
    document.getElementById('image-upload').addEventListener('change', function(e) {
      var file = e.target.files[0];
      if (!file) return;
      if (file.size > 5 * 1024 * 1024) { alert('이미지 크기는 5MB 이하만 가능합니다.'); return; }

      var progress = document.getElementById('upload-progress');
      progress.style.display = 'block';
      progress.textContent = '이미지 업로드 중...';

      var formData = new FormData();
      formData.append('image', file);

      fetch('/api/upload', { method: 'POST', credentials: 'include', body: formData })
        .then(function(r) {
          if (!r.ok) throw new Error('Upload failed');
          return r.json();
        })
        .then(function(data) {
          progress.style.display = 'none';
          insertText('\n![' + (file.name || '이미지') + '](' + data.url + ')\n');
        })
        .catch(function() {
          progress.style.display = 'none';
          alert('이미지 업로드에 실패했습니다.');
        });
      e.target.value = '';
    });

    // Drag & drop image upload
    textarea.addEventListener('dragover', function(e) { e.preventDefault(); textarea.style.background = '#f0fdf4'; });
    textarea.addEventListener('dragleave', function() { textarea.style.background = ''; });
    textarea.addEventListener('drop', function(e) {
      e.preventDefault();
      textarea.style.background = '';
      var file = e.dataTransfer.files[0];
      if (file && file.type.startsWith('image/')) {
        var input = document.getElementById('image-upload');
        var dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
        input.dispatchEvent(new Event('change'));
      }
    });

    // Paste image upload
    textarea.addEventListener('paste', function(e) {
      var items = e.clipboardData && e.clipboardData.items;
      if (!items) return;
      for (var i = 0; i < items.length; i++) {
        if (items[i].type.startsWith('image/')) {
          e.preventDefault();
          var file = items[i].getAsFile();
          var input = document.getElementById('image-upload');
          var dt = new DataTransfer();
          dt.items.add(file);
          input.files = dt.files;
          input.dispatchEvent(new Event('change'));
          break;
        }
      }
    });

    // Live preview
    function updatePreview() {
      var md = textarea.value;
      var preview = document.getElementById('preview');
      if (!md.trim()) {
        preview.innerHTML = '<p style="color:var(--color-neutral-400);">미리보기가 여기에 표시됩니다...</p>';
        return;
      }
      if (typeof marked !== 'undefined' && typeof DOMPurify !== 'undefined') {
        var html = marked.parse(md);
        preview.innerHTML = DOMPurify.sanitize(html);
      } else {
        preview.textContent = md;
      }
    }

    textarea.addEventListener('input', updatePreview);

    // Configure marked
    if (typeof marked !== 'undefined') {
      marked.setOptions({ breaks: true, gfm: true });
    }

    // Publish
    document.getElementById('publish-btn').addEventListener('click', function() {
      var title = document.getElementById('post-title').value.trim();
      var body = textarea.value.trim();
      var category = document.getElementById('post-category').value;
      var msgEl = document.getElementById('status-msg');

      if (!title) { showMsg('제목을 입력해주세요.', true); return; }
      if (!body) { showMsg('내용을 입력해주세요.', true); return; }
      if (body.length < 200) { showMsg('내용을 200자 이상 작성해주세요.', true); return; }

      var btn = document.getElementById('publish-btn');
      btn.disabled = true; btn.textContent = '발행 중...';

      fetch('/api/posts', {
        method: 'POST', credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category: category, title: title, body: body })
      })
      .then(function(r) {
        if (!r.ok) throw new Error('Failed');
        return r.json();
      })
      .then(function() {
        showMsg('글이 발행되었습니다! 잠시 후 이동합니다.', false);
        setTimeout(function() {
          location.href = '/category/' + category + '/';
        }, 1500);
      })
      .catch(function() {
        btn.disabled = false; btn.textContent = '발행하기';
        showMsg('발행에 실패했습니다. 로그인 상태를 확인해주세요.', true);
      });
    });

    function showMsg(msg, isError) {
      var el = document.getElementById('status-msg');
      el.textContent = msg;
      el.style.display = 'block';
      el.style.background = isError ? '#fef2f2' : '#f0fdf4';
      el.style.color = isError ? '#dc2626' : '#16a34a';
      if (isError) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // Tab key inserts spaces in textarea
    textarea.addEventListener('keydown', function(e) {
      if (e.key === 'Tab') {
        e.preventDefault();
        var start = this.selectionStart;
        this.setRangeText('  ', start, this.selectionEnd, 'end');
        updatePreview();
      }
    });
  </script>

  <style is:inline>
    .tb {
      padding: 0.3rem 0.6rem;
      border: 1px solid var(--color-border);
      border-radius: 6px;
      background: white;
      font-size: 0.75rem;
      cursor: pointer;
      color: var(--color-neutral-600);
      transition: all 0.15s;
      white-space: nowrap;
    }
    .tb:hover {
      background: var(--color-primary-50);
      border-color: var(--color-primary-300);
      color: var(--color-primary-600);
    }
    @media (max-width: 768px) {
      #editor-container {
        flex-direction: column !important;
      }
      #editor-container > div:first-child {
        border-right: none !important;
        border-bottom: 1px solid var(--color-border);
      }
      #editor-container textarea {
        min-height: 300px;
      }
      #preview {
        min-height: 300px;
      }
    }
  </style>
</BaseLayout>
