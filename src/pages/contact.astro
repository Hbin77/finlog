---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageTitle = '문의하기 - 핀로그';
const pageDescription = '핀로그에 문의하세요. 콘텐츠 관련 의견, 정보 수정 요청, 협업 제안 등 무엇이든 보내주세요.';

const breadcrumbItems = [
  { label: '홈', href: '/' },
  { label: '문의하기' },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8 py-10 md:py-16">
    <Breadcrumb items={breadcrumbItems} />

    <div class="mx-auto max-w-3xl">
      <div class="prose mb-10">
        <h1>문의하기</h1>
        <p>
          핀로그에 대한 의견이나 문의 사항이 있으시면 아래 양식을 이용해 주세요.
          콘텐츠 관련 제안, 정보 수정 요청, 협업 문의 등 무엇이든 환영합니다.
        </p>
      </div>

      <!-- Contact Info -->
      <div class="mb-10 grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="rounded-[var(--radius-lg)] bg-[var(--color-primary-50)] p-6">
          <h3 class="text-base font-semibold text-[var(--color-primary-800)] mb-2">이메일</h3>
          <p class="text-sm text-[var(--color-neutral-600)]">
            <a href="mailto:contact@finlog.kr" class="text-[var(--color-primary-600)] hover:underline">
              contact@finlog.kr
            </a>
          </p>
        </div>
        <div class="rounded-[var(--radius-lg)] bg-[var(--color-secondary-50)] p-6">
          <h3 class="text-base font-semibold text-[var(--color-secondary-800)] mb-2">응답 시간</h3>
          <p class="text-sm text-[var(--color-neutral-600)]">
            영업일 기준 2~3일 내 답변드립니다.
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <form class="space-y-6" action="#" method="POST">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-medium text-[var(--color-neutral-700)] mb-1.5">
              이름 <span class="text-[var(--color-error-500)]">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="홍길동"
              class="w-full rounded-[var(--radius-md)] border border-[var(--color-neutral-300)] px-4 py-2.5 text-sm text-[var(--color-neutral-800)] placeholder:text-[var(--color-neutral-400)] focus:border-[var(--color-primary-500)] focus:ring-2 focus:ring-[var(--color-primary-200)] focus:outline-none transition-colors"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-medium text-[var(--color-neutral-700)] mb-1.5">
              이메일 <span class="text-[var(--color-error-500)]">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="example@email.com"
              class="w-full rounded-[var(--radius-md)] border border-[var(--color-neutral-300)] px-4 py-2.5 text-sm text-[var(--color-neutral-800)] placeholder:text-[var(--color-neutral-400)] focus:border-[var(--color-primary-500)] focus:ring-2 focus:ring-[var(--color-primary-200)] focus:outline-none transition-colors"
            />
          </div>
        </div>

        <!-- Subject -->
        <div>
          <label for="subject" class="block text-sm font-medium text-[var(--color-neutral-700)] mb-1.5">
            제목 <span class="text-[var(--color-error-500)]">*</span>
          </label>
          <input
            type="text"
            id="subject"
            name="subject"
            required
            placeholder="문의 제목을 입력해 주세요"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-neutral-300)] px-4 py-2.5 text-sm text-[var(--color-neutral-800)] placeholder:text-[var(--color-neutral-400)] focus:border-[var(--color-primary-500)] focus:ring-2 focus:ring-[var(--color-primary-200)] focus:outline-none transition-colors"
          />
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-sm font-medium text-[var(--color-neutral-700)] mb-1.5">
            메시지 <span class="text-[var(--color-error-500)]">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            placeholder="문의 내용을 상세히 적어 주세요"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-neutral-300)] px-4 py-2.5 text-sm text-[var(--color-neutral-800)] placeholder:text-[var(--color-neutral-400)] focus:border-[var(--color-primary-500)] focus:ring-2 focus:ring-[var(--color-primary-200)] focus:outline-none transition-colors resize-y"
          ></textarea>
        </div>

        <!-- Privacy Consent -->
        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="privacy-consent"
            name="privacy-consent"
            required
            class="mt-1 h-4 w-4 rounded border-[var(--color-neutral-300)] text-[var(--color-primary-600)] focus:ring-[var(--color-primary-500)]"
          />
          <label for="privacy-consent" class="text-sm text-[var(--color-neutral-600)]">
            <a href="/privacy-policy/" class="text-[var(--color-primary-600)] hover:underline">개인정보처리방침</a>에
            동의하며, 문의 처리를 위한 개인정보 수집 및 이용에 동의합니다.
            <span class="text-[var(--color-error-500)]">*</span>
          </label>
        </div>

        <!-- Submit -->
        <div>
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-[var(--radius-md)] bg-[var(--color-primary-600)] px-6 py-3 text-sm font-semibold text-white shadow-[var(--shadow-sm)] hover:bg-[var(--color-primary-500)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary-500)] focus:ring-offset-2 transition-colors"
          >
            문의 보내기
          </button>
        </div>
      </form>

      <!-- Additional Info -->
      <div class="mt-12 rounded-[var(--radius-lg)] border border-[var(--color-neutral-200)] bg-white p-6">
        <h3 class="text-base font-semibold text-[var(--color-neutral-800)] mb-3">문의 시 참고 사항</h3>
        <ul class="space-y-2 text-sm text-[var(--color-neutral-600)]">
          <li>콘텐츠 내용에 오류가 있는 경우, 해당 글의 URL과 함께 알려주시면 빠르게 수정하겠습니다.</li>
          <li>광고, 협업, 기고 관련 문의도 환영합니다.</li>
          <li>개인적인 재무 상담은 제공하지 않습니다. 전문 재무설계사와의 상담을 권장합니다.</li>
          <li>영업일 기준 2~3일 내에 이메일로 답변드립니다.</li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>
