---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="비밀번호 재설정 | 핀로그" noindex={true}>
  <section style="max-width:400px;margin:0 auto;padding:4rem 1rem;">
    <div style="background:white;border:1px solid var(--color-border);border-radius:16px;padding:2rem;">
      <h1 style="font-size:1.3rem;font-weight:800;color:var(--color-neutral-900);margin-bottom:0.5rem;text-align:center;">비밀번호 재설정</h1>
      <p style="font-size:0.85rem;color:var(--color-neutral-500);text-align:center;margin-bottom:1.5rem;">새로운 비밀번호를 입력해주세요.</p>

      <div id="reset-msg" style="display:none;margin-bottom:1rem;padding:0.6rem 0.8rem;border-radius:8px;font-size:0.82rem;"></div>

      <div style="margin-bottom:1rem;">
        <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">새 비밀번호</label>
        <input id="reset-pw" type="password" placeholder="8자 이상" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
      </div>
      <div style="margin-bottom:1.5rem;">
        <label style="display:block;font-size:0.8rem;font-weight:600;color:#555;margin-bottom:0.3rem;">비밀번호 확인</label>
        <input id="reset-pw2" type="password" placeholder="비밀번호 재입력" style="width:100%;padding:0.6rem 0.75rem;border:1px solid #ddd;border-radius:8px;font-size:0.9rem;box-sizing:border-box;" />
      </div>

      <button onclick="doReset()" id="reset-btn" style="width:100%;padding:0.7rem;background:var(--color-primary-500);color:white;border:none;border-radius:10px;font-size:0.9rem;font-weight:600;cursor:pointer;">비밀번호 변경</button>
    </div>
  </section>

  <script is:inline>
    function doReset() {
      var pw = document.getElementById('reset-pw').value;
      var pw2 = document.getElementById('reset-pw2').value;
      var msgEl = document.getElementById('reset-msg');
      var params = new URLSearchParams(window.location.search);
      var token = params.get('token');

      if (!token) { showResetMsg('유효하지 않은 링크입니다.', true); return; }
      if (!pw || pw.length < 8) { showResetMsg('비밀번호는 8자 이상이어야 합니다.', true); return; }
      if (pw !== pw2) { showResetMsg('비밀번호가 일치하지 않습니다.', true); return; }

      var btn = document.getElementById('reset-btn');
      btn.disabled = true; btn.textContent = '처리중...';

      fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token: token, password: pw })
      })
      .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
      .then(function(res) {
        btn.disabled = false; btn.textContent = '비밀번호 변경';
        if (res.ok && res.data.success) {
          showResetMsg('비밀번호가 변경되었습니다! 로그인해주세요.', false);
          setTimeout(function() { location.href = '/'; }, 2000);
        } else {
          showResetMsg(res.data.error || '변경에 실패했습니다.', true);
        }
      });
    }

    function showResetMsg(msg, isError) {
      var el = document.getElementById('reset-msg');
      el.textContent = msg;
      el.style.display = 'block';
      el.style.background = isError ? '#fef2f2' : '#f0fdf4';
      el.style.color = isError ? '#dc2626' : '#16a34a';
    }
  </script>
</BaseLayout>
