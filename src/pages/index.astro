---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import CategoryTag from '../components/CategoryTag.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = [
  {
    id: 'saving' as const,
    label: '저축/예금 전략',
    desc: '월급 관리부터 적금, 비상금 마련까지 안정적인 자산 형성의 첫걸음',
    href: '/category/saving/',
    icon: 'piggy',
  },
  {
    id: 'investing' as const,
    label: '투자 입문',
    desc: 'ETF, 주식, 펀드 등 처음 투자를 시작하는 직장인을 위한 가이드',
    href: '/category/investing/',
    icon: 'chart',
  },
  {
    id: 'tax' as const,
    label: '세금/연말정산',
    desc: '소득공제, 세액공제, 절세 전략을 한눈에 정리',
    href: '/category/tax/',
    icon: 'receipt',
  },
  {
    id: 'tools' as const,
    label: '재테크 도구 리뷰',
    desc: '가계부 앱, 은행 서비스, 자산관리 플랫폼 비교 분석',
    href: '/category/tools/',
    icon: 'tool',
  },
  {
    id: 'tips' as const,
    label: '생활비 절약 팁',
    desc: '식비, 통신비, 보험료 등 매달 체감되는 실생활 절약법',
    href: '/category/tips/',
    icon: 'bulb',
  },
];

const valueProps = [
  {
    title: '체계적인 저축 전략',
    desc: '사회초년생부터 경력직까지, 단계별 저축 로드맵을 제공합니다.',
    icon: 'vault',
  },
  {
    title: '쉬운 투자 가이드',
    desc: '복잡한 투자 용어를 풀어서, 첫 투자를 자신 있게 시작하세요.',
    icon: 'trending',
  },
  {
    title: '절세 핵심 정리',
    desc: '연말정산, 세액공제 등 직장인이 꼭 알아야 할 절세 전략.',
    icon: 'shield',
  },
  {
    title: '실전 절약 노하우',
    desc: '매달 고정비를 줄이는 검증된 방법과 앱 활용 팁.',
    icon: 'wallet',
  },
];
---

<BaseLayout title="핀로그 | 2030 직장인을 위한 실용 재테크 가이드">

  <!-- ============================================
       HERO SECTION
       ============================================ -->
  <section class="hero-section relative overflow-hidden">
    <!-- Subtle decorative elements -->
    <div class="hero-ornament hero-ornament--1" aria-hidden="true"></div>
    <div class="hero-ornament hero-ornament--2" aria-hidden="true"></div>

    <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="hero-inner">
        <div class="hero-badge">
          <span class="hero-badge__dot" aria-hidden="true"></span>
          실용 재테크 블로그
        </div>

        <h1 class="hero-title">
          2030 직장인을 위한<br />
          <span class="hero-title__accent">실용 재테크 가이드</span>
        </h1>

        <p class="hero-desc">
          월급 관리, 저축, 투자, 세금, 절약까지.<br class="hidden sm:inline" />
          복잡한 금융 정보를 쉽고 실용적으로 정리합니다.
        </p>

        <div class="hero-actions">
          <a href="/blog/" class="btn-primary">
            콘텐츠 둘러보기
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="#categories" class="btn-ghost">
            카테고리 보기
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="hero-stats">
          <div class="hero-stat">
            <span class="hero-stat__number">{allPosts.length}</span>
            <span class="hero-stat__label">게시글</span>
          </div>
          <div class="hero-stat__divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat__number">5</span>
            <span class="hero-stat__label">카테고리</span>
          </div>
          <div class="hero-stat__divider" aria-hidden="true"></div>
          <div class="hero-stat">
            <span class="hero-stat__number">100%</span>
            <span class="hero-stat__label">무료 가이드</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       VALUE PROPOSITIONS
       ============================================ -->
  <section class="py-16 md:py-24 bg-[var(--color-neutral-50)]">
    <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label">핀로그가 드리는 가치</p>
        <h2 class="section-title">똑똑한 재테크, 여기서 시작하세요</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {valueProps.map((prop) => (
          <div class="value-card">
            <div class="value-card__icon">
              {prop.icon === 'vault' && (
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                </svg>
              )}
              {prop.icon === 'trending' && (
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
                </svg>
              )}
              {prop.icon === 'shield' && (
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
                </svg>
              )}
              {prop.icon === 'wallet' && (
                <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3" />
                </svg>
              )}
            </div>
            <h3 class="value-card__title">{prop.title}</h3>
            <p class="value-card__desc">{prop.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       LATEST POSTS
       ============================================ -->
  {latestPosts.length > 0 && (
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8">
        <div class="flex items-end justify-between mb-10 md:mb-14">
          <div>
            <p class="section-label">최근 콘텐츠</p>
            <h2 class="section-title">최신 글</h2>
          </div>
          <a href="/blog/" class="view-all-link">
            전체 보기
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {latestPosts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ============================================
       CATEGORY NAVIGATION
       ============================================ -->
  <section id="categories" class="py-16 md:py-24 bg-[var(--color-neutral-50)]">
    <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label">주제별 탐색</p>
        <h2 class="section-title">카테고리</h2>
        <p class="section-subtitle">관심 있는 분야를 선택해 맞춤 콘텐츠를 확인하세요.</p>
      </div>

      <div class="category-grid">
        {categories.map((cat) => (
          <a href={cat.href} class="category-card" data-category={cat.id}>
            <div class="category-card__icon-wrap" data-category={cat.id}>
              {cat.icon === 'piggy' && (
                <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
                </svg>
              )}
              {cat.icon === 'chart' && (
                <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                </svg>
              )}
              {cat.icon === 'receipt' && (
                <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 14.25l6-6m4.5-3.493V21.75l-3.75-1.5-3.75 1.5-3.75-1.5-3.75 1.5V4.757c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0c1.1.128 1.907 1.077 1.907 2.185zM9.75 9h.008v.008H9.75V9zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 4.5h.008v.008h-.008V13.5zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
              )}
              {cat.icon === 'tool' && (
                <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1 5.1a2.121 2.121 0 11-3-3l5.1-5.1m0 0L3.34 8.41a1.5 1.5 0 010-2.12l.88-.88a1.5 1.5 0 012.12 0l3.75 3.75m1.33 1.01l3.49-3.49a1.5 1.5 0 012.12 0l.88.88a1.5 1.5 0 010 2.12l-3.49 3.49m-4.5-4.5l4.5 4.5M14.5 6.5l3 3" />
                </svg>
              )}
              {cat.icon === 'bulb' && (
                <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
                </svg>
              )}
            </div>
            <div class="category-card__content">
              <div class="category-card__tag-wrap">
                <CategoryTag category={cat.id} size="sm" />
              </div>
              <h3 class="category-card__title">{cat.label}</h3>
              <p class="category-card__desc">{cat.desc}</p>
            </div>
            <div class="category-card__arrow" aria-hidden="true">
              <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CTA / NEWSLETTER SECTION
       ============================================ -->
  <section class="py-16 md:py-24">
    <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8">
      <div class="cta-card">
        <div class="cta-card__inner">
          <div class="cta-card__content">
            <p class="section-label" style="text-align: left;">시작하기</p>
            <h2 class="cta-card__title">
              재테크, 어디서부터 시작해야 할지<br class="hidden md:inline" />
              모르겠다면?
            </h2>
            <p class="cta-card__desc">
              핀로그에서 단계별 가이드를 확인하세요. 사회초년생부터 경력직까지,
              누구나 따라할 수 있는 실용적인 재테크 정보를 제공합니다.
            </p>
            <div class="cta-card__actions">
              <a href="/blog/" class="btn-primary">
                글 모아보기
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <a href="/category/saving/" class="btn-ghost">
                저축부터 시작하기
              </a>
            </div>
          </div>
          <div class="cta-card__visual" aria-hidden="true">
            <div class="cta-visual-ring cta-visual-ring--1"></div>
            <div class="cta-visual-ring cta-visual-ring--2"></div>
            <div class="cta-visual-ring cta-visual-ring--3"></div>
            <svg class="cta-visual-icon" width="48" height="48" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================
     HERO SECTION
     ============================================ */
  .hero-section {
    padding: var(--space-20) 0;
    background-color: var(--color-neutral-50);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .hero-section {
      padding: var(--space-24) 0 var(--space-20);
    }
  }

  .hero-ornament {
    position: absolute;
    border-radius: 50%;
    opacity: 0.35;
    pointer-events: none;
  }

  .hero-ornament--1 {
    width: 400px;
    height: 400px;
    top: -120px;
    right: -80px;
    background: radial-gradient(circle, var(--color-primary-100) 0%, transparent 70%);
  }

  .hero-ornament--2 {
    width: 300px;
    height: 300px;
    bottom: -60px;
    left: -60px;
    background: radial-gradient(circle, var(--color-secondary-100) 0%, transparent 70%);
  }

  .hero-inner {
    max-width: 720px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background-color: var(--color-primary-50);
    border: 1px solid var(--color-primary-200);
    border-radius: var(--radius-full);
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary-600);
    margin-bottom: var(--space-6);
    letter-spacing: var(--letter-spacing-wide);
  }

  .hero-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-secondary-500);
  }

  .hero-title {
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--color-primary-800);
    margin-bottom: var(--space-5);
  }

  @media (min-width: 768px) {
    .hero-title {
      font-size: var(--font-size-display);
    }
  }

  .hero-title__accent {
    color: var(--color-secondary-600);
  }

  .hero-desc {
    font-size: var(--font-size-body);
    line-height: var(--line-height-relaxed);
    color: var(--color-text-sub);
    margin-bottom: var(--space-8);
    max-width: 560px;
  }

  @media (min-width: 768px) {
    .hero-desc {
      font-size: 1.125rem;
    }
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat__number {
    font-size: var(--font-size-h3);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-500);
    line-height: 1;
  }

  .hero-stat__label {
    font-size: var(--font-size-caption);
    color: var(--color-text-sub);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-wide);
  }

  .hero-stat__divider {
    width: 1px;
    height: 32px;
    background-color: var(--color-border);
  }

  /* ============================================
     SHARED ELEMENTS
     ============================================ */

  .section-label {
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-semibold);
    color: var(--color-secondary-500);
    letter-spacing: var(--letter-spacing-wide);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
  }

  .section-title {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-bold);
    color: var(--color-primary-800);
