---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="꿀팁 공유 게시판 | 핀로그" description="직장인들의 실전 재테크 노하우를 공유하는 공간입니다. 저축, 투자, 세금, 절약 꿀팁을 나눠보세요.">
  <section style="max-width: var(--container-max-width); margin: 0 auto; padding: 2.5rem 1rem 4rem;">
    <!-- Hero + Auth -->
    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem;">
      <div>
        <h1 style="font-size: 2rem; font-weight: 800; color: var(--color-neutral-900); margin-bottom: 0.5rem;">재테크 꿀팁 공유</h1>
        <p style="font-size: 1.05rem; color: var(--color-neutral-500); max-width: 480px;">직장인들의 실전 노하우를 공유하고, 다른 사람들의 꿀팁을 배워보세요</p>
      </div>
      <div id="auth-section" style="display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0;">
        <!-- filled by JS -->
      </div>
    </div>

    <!-- Write button + form -->
    <div id="write-section" style="display: none; margin-bottom: 2rem;">
      <button id="write-toggle-btn" onclick="toggleWriteForm()" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.25rem; background: var(--color-primary-500); color: white; border: none; border-radius: 10px; font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: background 0.2s;">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        꿀팁 작성하기
      </button>
      <div id="write-form" style="display: none; margin-top: 1rem; background: white; border: 1px solid var(--color-border); border-radius: 14px; padding: 1.5rem;">
        <div style="display: flex; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap;">
          <select id="post-category" style="padding: 0.5rem 0.75rem; border: 1px solid var(--color-border); border-radius: 8px; font-size: 0.9rem; color: var(--color-neutral-700); background: white;">
            <option value="저축/예금">저축/예금</option>
            <option value="투자">투자</option>
            <option value="세금">세금</option>
            <option value="절약">절약</option>
            <option value="앱/도구">앱/도구</option>
            <option value="자유">자유</option>
          </select>
          <input id="post-title" type="text" placeholder="제목을 입력하세요" style="flex: 1; min-width: 200px; padding: 0.5rem 0.75rem; border: 1px solid var(--color-border); border-radius: 8px; font-size: 0.9rem;" />
        </div>
        <textarea id="post-body" placeholder="내용을 작성해주세요..." rows="5" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-border); border-radius: 8px; font-size: 0.9rem; resize: vertical; margin-bottom: 1rem; box-sizing: border-box;"></textarea>
        <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
          <button onclick="toggleWriteForm()" style="padding: 0.5rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: white; font-size: 0.85rem; cursor: pointer; color: var(--color-neutral-600);">취소</button>
          <button onclick="submitPost()" style="padding: 0.5rem 1rem; background: var(--color-primary-500); color: white; border: none; border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer;">등록하기</button>
        </div>
      </div>
    </div>

    <!-- Category filter tabs -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 2rem;" id="category-tabs">
      <button class="cat-tab active" data-cat="">전체</button>
      <button class="cat-tab" data-cat="저축/예금">저축/예금</button>
      <button class="cat-tab" data-cat="투자">투자</button>
      <button class="cat-tab" data-cat="세금">세금</button>
      <button class="cat-tab" data-cat="절약">절약</button>
      <button class="cat-tab" data-cat="앱/도구">앱/도구</button>
    </div>

    <!-- Posts list -->
    <div id="posts-list" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
      <div style="grid-column: 1/-1; text-align: center; padding: 3rem 1rem; color: var(--color-neutral-400);">게시글을 불러오는 중...</div>
    </div>

    <!-- Pagination -->
    <div id="pagination" style="display: flex; justify-content: center; gap: 0.5rem;"></div>

    <!-- Expanded post overlay -->
    <div id="post-detail" style="display: none; position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.4); overflow-y: auto;">
      <div style="max-width: 680px; margin: 2rem auto; background: white; border-radius: 16px; padding: 2rem; position: relative; min-height: 200px;" id="post-detail-inner">
      </div>
    </div>
  </section>

  <script is:inline>
    var currentUser = null;
    var currentCategory = '';
    var currentPage = 1;

    var CATEGORY_COLORS = {
      '저축/예금': { bg: 'var(--color-primary-50)', color: 'var(--color-primary-600)' },
      '투자': { bg: '#fef3c7', color: '#d97706' },
      '세금': { bg: '#f5f3ff', color: '#7c3aed' },
      '절약': { bg: '#f0fdf4', color: '#16a34a' },
      '앱/도구': { bg: '#fce7f3', color: '#db2777' },
      '자유': { bg: '#f1f5f9', color: '#475569' }
    };

    function formatDate(d) {
      var dt = new Date(d);
      return dt.getFullYear() + '.' + String(dt.getMonth()+1).padStart(2,'0') + '.' + String(dt.getDate()).padStart(2,'0');
    }

    function truncate(s, n) {
      if (!s) return '';
      return s.length > n ? s.substring(0, n) + '...' : s;
    }

    function checkAuth() {
      fetch('/api/auth/me', { credentials: 'include' })
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(data) {
          var el = document.getElementById('auth-section');
          var ws = document.getElementById('write-section');
          if (data && data.user) {
            currentUser = data.user;
            var name = data.user.nickname || data.user.name || '사용자';
            el.innerHTML = '<span style="font-size:0.85rem;color:var(--color-neutral-600);">' + name + '님</span>' +
              '<button onclick="logout()" style="padding:0.35rem 0.75rem;border:1px solid var(--color-border);border-radius:8px;background:white;font-size:0.8rem;cursor:pointer;color:var(--color-neutral-600);">로그아웃</button>';
            ws.style.display = 'block';
          } else {
            currentUser = null;
            el.innerHTML =
              '<a href="/api/auth/google" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.45rem 1rem;border:1px solid var(--color-border);border-radius:8px;background:white;font-size:0.82rem;color:var(--color-neutral-700);text-decoration:none;font-weight:500;transition:border-color 0.2s;"><svg width="14" height="14" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>Google로 로그인</a>' +
              '<a href="/api/auth/kakao" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.45rem 1rem;border-radius:8px;background:#FEE500;font-size:0.82rem;color:#3C1E1E;text-decoration:none;font-weight:500;border:none;">카카오로 로그인</a>';
            ws.style.display = 'none';
          }
        })
        .catch(function() {
          var el = document.getElementById('auth-section');
          el.innerHTML =
            '<a href="/api/auth/google" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.45rem 1rem;border:1px solid var(--color-border);border-radius:8px;background:white;font-size:0.82rem;color:var(--color-neutral-700);text-decoration:none;font-weight:500;">Google로 로그인</a>' +
            '<a href="/api/auth/kakao" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.45rem 1rem;border-radius:8px;background:#FEE500;font-size:0.82rem;color:#3C1E1E;text-decoration:none;font-weight:500;">카카오로 로그인</a>';
        });
    }

    function logout() {
      fetch('/api/auth/logout', { method: 'POST', credentials: 'include' })
        .then(function() { location.reload(); });
    }

    function toggleWriteForm() {
      var f = document.getElementById('write-form');
      f.style.display = f.style.display === 'none' ? 'block' : 'none';
    }

    function submitPost() {
      var cat = document.getElementById('post-category').value;
      var title = document.getElementById('post-title').value.trim();
      var body = document.getElementById('post-body').value.trim();
      if (!title) { alert('제목을 입력해주세요.'); return; }
      if (!body) { alert('내용을 입력해주세요.'); return; }
      fetch('/api/posts', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category: cat, title: title, body: body })
      }).then(function(r) {
        if (!r.ok) throw new Error('Failed');
        document.getElementById('post-title').value = '';
        document.getElementById('post-body').value = '';
        document.getElementById('write-form').style.display = 'none';
        loadPosts();
      }).catch(function() { alert('게시글 등록에 실패했습니다. 로그인 상태를 확인해주세요.'); });
    }

    function loadPosts() {
      var url = '/api/posts?page=' + currentPage;
      if (currentCategory) url += '&category=' + encodeURIComponent(currentCategory);
      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          renderPosts(data.posts || []);
          renderPagination(data.totalPages || 1, data.page || 1);
        })
        .catch(function() {
          document.getElementById('posts-list').innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--color-neutral-400);">게시글을 불러올 수 없습니다.</div>';
        });
    }

    function renderPosts(posts) {
      var el = document.getElementById('posts-list');
      if (!posts.length) {
        el.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:3rem 1rem;color:var(--color-neutral-400);">아직 게시글이 없습니다. 첫 번째 꿀팁을 공유해보세요!</div>';
        return;
      }
      var html = '';
      posts.forEach(function(p) {
        var cc = CATEGORY_COLORS[p.category] || CATEGORY_COLORS['자유'];
        var initial = (p.author_nickname || '?')[0];
        html += '<div class="post-card" onclick="openPost(' + p.id + ')" style="background:white;border-radius:14px;padding:1.25rem;border:1px solid var(--color-border);cursor:pointer;transition:box-shadow 0.2s,transform 0.15s;" onmouseover="this.style.boxShadow=\'0 4px 20px rgba(0,0,0,0.08)\';this.style.transform=\'translateY(-2px)\'" onmouseout="this.style.boxShadow=\'none\';this.style.transform=\'none\'">' +
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">' +
            '<span style="display:inline-block;font-size:0.72rem;padding:0.2rem 0.6rem;border-radius:999px;background:' + cc.bg + ';color:' + cc.color + ';font-weight:600;">' + p.category + '</span>' +
            '<span style="font-size:0.75rem;color:var(--color-neutral-400);">' + formatDate(p.created_at) + '</span>' +
          '</div>' +
          '<h3 style="font-size:1rem;font-weight:700;color:var(--color-neutral-800);margin-bottom:0.5rem;line-height:1.4;">' + escapeHtml(p.title) + '</h3>' +
          '<p style="font-size:0.88rem;color:var(--color-neutral-500);line-height:1.55;margin-bottom:0.75rem;">' + escapeHtml(truncate(p.body, 120)) + '</p>' +
          '<div style="display:flex;justify-content:space-between;align-items:center;">' +
            '<span style="display:inline-flex;align-items:center;gap:0.4rem;font-size:0.8rem;color:var(--color-neutral-500);">' +
              '<span style="width:22px;height:22px;border-radius:50%;background:var(--color-primary-100);color:var(--color-primary-600);display:inline-flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:700;">' + escapeHtml(initial) + '</span>' +
              escapeHtml(p.author_nickname || '익명') +
            '</span>' +
            '<span style="font-size:0.8rem;color:var(--color-neutral-400);display:inline-flex;align-items:center;gap:0.3rem;">' +
              '<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>' +
              (p.likes_count || 0) +
            '</span>' +
          '</div>' +
        '</div>';
      });
      el.innerHTML = html;
    }

    function escapeHtml(s) {
      if (!s) return '';
      return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function renderPagination(total, page) {
      var el = document.getElementById('pagination');
      if (total <= 1) { el.innerHTML = ''; return; }
      var html = '';
      for (var i = 1; i <= total; i++) {
        var active = i === page;
        html += '<button onclick="goPage(' + i + ')" style="width:36px;height:36px;border-radius:8px;border:1px solid ' + (active ? 'var(--color-primary-500)' : 'var(--color-border)') + ';background:' + (active ? 'var(--color-primary-500)' : 'white') + ';color:' + (active ? 'white' : 'var(--color-neutral-600)') + ';font-size:0.85rem;font-weight:600;cursor:pointer;">' + i + '</button>';
      }
      el.innerHTML = html;
    }

    function goPage(p) {
      currentPage = p;
      loadPosts();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function openPost(id) {
      var overlay = document.getElementById('post-detail');
      var inner = document.getElementById('post-detail-inner');
      overlay.style.display = 'block';
      document.body.style.overflow = 'hidden';
      inner.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--color-neutral-400);">불러오는 중...</div>';

      fetch('/api/posts/' + id, { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(p) {
          var cc = CATEGORY_COLORS[p.category] || CATEGORY_COLORS['자유'];
          var canDelete = currentUser && (currentUser.id === p.author_id);
          var html = '<button onclick="closePost()" style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--color-neutral-400);line-height:1;">&times;</button>' +
            '<div style="margin-bottom:1rem;">' +
              '<span style="display:inline-block;font-size:0.75rem;padding:0.25rem 0.7rem;border-radius:999px;background:' + cc.bg + ';color:' + cc.color + ';font-weight:600;">' + escapeHtml(p.category) + '</span>' +
            '</div>' +
            '<h2 style="font-size:1.35rem;font-weight:800;color:var(--color-neutral-900);margin-bottom:0.75rem;">' + escapeHtml(p.title) + '</h2>' +
            '<div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;font-size:0.82rem;color:var(--color-neutral-500);">' +
              '<span>' + escapeHtml(p.author_nickname || '익명') + '</span>' +
              '<span>&middot;</span>' +
              '<span>' + formatDate(p.created_at) + '</span>' +
              (canDelete ? '<button onclick="deletePost(' + p.id + ')" style="margin-left:auto;padding:0.3rem 0.7rem;border:1px solid #fca5a5;border-radius:6px;background:#fef2f2;color:#dc2626;font-size:0.75rem;cursor:pointer;">삭제</button>' : '') +
            '</div>' +
            '<div style="font-size:0.95rem;line-height:1.8;color:var(--color-neutral-700);white-space:pre-wrap;margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--color-border);">' + escapeHtml(p.body) + '</div>' +
            '<div id="comments-section">' +
              '<h3 style="font-size:1rem;font-weight:700;color:var(--color-neutral-800);margin-bottom:1rem;">댓글</h3>' +
              '<div id="comments-list" style="margin-bottom:1rem;"></div>' +
              (currentUser ? '<div style="display:flex;gap:0.5rem;"><input id="comment-input" type="text" placeholder="댓글을 입력하세요..." style="flex:1;padding:0.5rem 0.75rem;border:1px solid var(--color-border);border-radius:8px;font-size:0.88rem;" onkeydown="if(event.key===\'Enter\')addComment(' + p.id + ')"/><button onclick="addComment(' + p.id + ')" style="padding:0.5rem 1rem;background:var(--color-primary-500);color:white;border:none;border-radius:8px;font-size:0.85rem;font-weight:600;cursor:pointer;white-space:nowrap;">등록</button></div>' : '<p style="font-size:0.85rem;color:var(--color-neutral-400);">댓글을 작성하려면 로그인해주세요.</p>') +
            '</div>';
          inner.innerHTML = html;
          loadComments(p.id);
        })
        .catch(function() {
          inner.innerHTML = '<div style="text-align:center;padding:2rem;color:var(--color-neutral-400);">게시글을 불러올 수 없습니다.</div><button onclick="closePost()" style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--color-neutral-400);">&times;</button>';
        });
    }

    function closePost() {
      document.getElementById('post-detail').style.display = 'none';
      document.body.style.overflow = '';
    }

    function deletePost(id) {
      if (!confirm('정말 삭제하시겠습니까?')) return;
      fetch('/api/posts/' + id, { method: 'DELETE', credentials: 'include' })
        .then(function(r) {
          if (!r.ok) throw new Error('Failed');
          closePost();
          loadPosts();
        })
        .catch(function() { alert('삭제에 실패했습니다.'); });
    }

    function loadComments(postId) {
      fetch('/api/posts/' + postId + '/comments', { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var el = document.getElementById('comments-list');
          var comments = data.comments || data || [];
          if (!comments.length) {
            el.innerHTML = '<p style="font-size:0.85rem;color:var(--color-neutral-400);padding:0.5rem 0;">아직 댓글이 없습니다.</p>';
            return;
          }
          var html = '';
          comments.forEach(function(c) {
            html += '<div style="padding:0.75rem 0;border-bottom:1px solid var(--color-border);">' +
              '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.3rem;">' +
                '<span style="font-size:0.82rem;font-weight:600;color:var(--color-neutral-700);">' + escapeHtml(c.author_nickname || '익명') + '</span>' +
                '<span style="font-size:0.72rem;color:var(--color-neutral-400);">' + formatDate(c.created_at) + '</span>' +
              '</div>' +
              '<p style="font-size:0.88rem;color:var(--color-neutral-600);line-height:1.5;">' + escapeHtml(c.body) + '</p>' +
            '</div>';
          });
          el.innerHTML = html;
        });
    }

    function addComment(postId) {
      var input = document.getElementById('comment-input');
      var body = input.value.trim();
      if (!body) return;
      fetch('/api/posts/' + postId + '/comments', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body: body })
      }).then(function(r) {
        if (!r.ok) throw new Error('Failed');
        input.value = '';
        loadComments(postId);
      }).catch(function() { alert('댓글 등록에 실패했습니다.'); });
    }

    // Close overlay on background click
    document.getElementById('post-detail').addEventListener('click', function(e) {
      if (e.target === this) closePost();
    });

    // Category tabs
    document.querySelectorAll('.cat-tab').forEach(function(tab) {
      tab.addEventListener('click', function() {
        document.querySelectorAll('.cat-tab').forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        currentCategory = tab.getAttribute('data-cat');
        currentPage = 1;
        loadPosts();
      });
    });

    // Init
    document.addEventListener('DOMContentLoaded', function() {
      checkAuth();
      loadPosts();
    });
  </script>

  <style is:inline>
    .cat-tab {
      padding: 0.5rem 1.1rem;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      background: white;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-neutral-600);
      cursor: pointer;
      transition: all 0.2s;
    }
    .cat-tab:hover {
      border-color: var(--color-primary-400);
      color: var(--color-primary-600);
    }
    .cat-tab.active {
      background: var(--color-primary-500);
      color: white;
      border-color: var(--color-primary-500);
    }
    #post-detail-inner {
      animation: slideUp 0.25s ease-out;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
