---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없습니다 | 핀로그" description="요청하신 페이지를 찾을 수 없습니다." noindex={true}>
  <div class="mx-auto max-w-[var(--container-max-width)] px-4 sm:px-6 lg:px-8 py-20 md:py-32">
    <div class="text-center max-w-lg mx-auto">
      <p style="font-size:5rem;font-weight:800;color:var(--color-primary-500);margin-bottom:0.5rem;">404</p>
      <h1 style="font-size:1.5rem;font-weight:700;color:var(--color-neutral-900);margin-bottom:1rem;">페이지를 찾을 수 없습니다</h1>
      <p style="font-size:1rem;color:var(--color-neutral-500);margin-bottom:2rem;line-height:1.6;">
        요청하신 페이지가 삭제되었거나 주소가 변경되었을 수 있습니다.
      </p>
      <div style="display:flex;justify-content:center;gap:0.75rem;flex-wrap:wrap;">
        <a href="/" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.65rem 1.5rem;background:var(--color-primary-500);color:white;border-radius:10px;font-size:0.9rem;font-weight:600;text-decoration:none;">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          홈으로 가기
        </a>
        <a href="/blog/" style="display:inline-flex;align-items:center;gap:0.4rem;padding:0.65rem 1.5rem;border:1px solid var(--color-border);border-radius:10px;font-size:0.9rem;font-weight:600;color:var(--color-neutral-700);text-decoration:none;">
          블로그 보기
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
